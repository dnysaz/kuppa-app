<div class="max-w-3xl mx-auto py-12 px-4">
    <div class="mb-4">
        <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
            {{blog.category}}
        </span>
    </div>

    <h1 class="text-5xl font-extrabold mb-6 text-gray-900 leading-tight">{{blog.title}}</h1>
    
    <div class="flex items-center mb-8 pb-8 border-b border-gray-100">
        <div class="flex-shrink-0">
            <img class="h-12 w-12 rounded-full bg-gray-200 object-cover border-2 border-white shadow-sm" 
                 src="{{blog.profiles.avatar_url}}" 
                 alt="{{blog.profiles.full_name}}">
        </div>
        <div class="ml-4">
            <p class="text-sm font-bold text-gray-900 leading-none">
                {{blog.profiles.full_name}}
            </p>
            <p class="text-xs text-gray-500 mt-1">
                Published on {{blog.created_at}}
            </p>
        </div>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
        {{blog.body}}
    </div>

    <div class="mt-12 pt-6 border-t border-gray-100">
        <a href="{{route 'blog'}}" class="text-blue-600 hover:text-blue-800 font-medium flex items-center gap-2 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Articles
        </a>
    </div>
</div>