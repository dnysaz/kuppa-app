{{set "title" title}}
{{set "description" description}}

<section class="max-w-5xl mx-auto py-10 px-4">
    <header class="mb-10 flex justify-between items-end">
        <div>
            <h1 class="text-4xl font-bold text-gray-900 mb-2">{{title}}</h1>
            <p class="text-gray-600 italic text-lg">{{description}}</p>
        </div>
        <a href="{{route 'blog'}}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium transition">
            + New Post
        </a>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {{!-- FIX: Looping ke blogs.data karena kita menggunakan .paginate() --}}
        {{#each blogs.data}}
        <article class="relative border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 bg-white">
            
            <div class="absolute top-4 right-4 flex gap-2">
                <a href="{{ route 'blog.edit' slug=this.slug }}" class="p-2 bg-gray-50 hover:bg-yellow-100 text-gray-400 hover:text-yellow-600 rounded-full transition-colors border border-gray-100 shadow-sm" title="Edit Post">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </a>
                <form action="{{ route 'blog.delete' slug=this.slug }}" method="POST" onsubmit="return confirm('Are you sure?')">
                    <button type="submit" class="p-2 bg-gray-50 hover:bg-red-100 text-gray-400 hover:text-red-600 rounded-full transition-colors border border-gray-100 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </form>
            </div>

            <div class="p-6">
                <div class="flex items-center gap-2 mb-3">
                    <span class="bg-blue-100 text-blue-700 text-xs font-semibold px-2.5 py-0.5 rounded uppercase">
                        {{this.category}}
                    </span>
                    <span class="text-gray-400 text-xs">•</span>
                    <span class="text-gray-500 text-xs uppercase">{{this.status}}</span>
                </div>

                <h2 class="text-2xl font-bold text-gray-800 mb-3 hover:text-blue-600 transition-colors pr-8">
                    <a href="{{ route 'blog.show' slug=this.slug }}">{{this.title}}</a>
                </h2>

                <p class="text-gray-600 mb-4 line-clamp-3">
                    {{this.body}}
                </p>

                <div class="flex items-center mt-6 pt-6 border-t border-gray-100">
                    <div class="flex-shrink-0">
                        <img class="h-10 w-10 rounded-full bg-gray-200 object-cover" src="{{this.profiles.avatar_url}}" alt="{{this.profiles.full_name}}">
                    </div>
                    <div class="ml-3">
                        <p class="text-sm font-medium text-gray-900">
                            {{this.profiles.full_name}}
                        </p>
                        <p class="text-xs text-gray-500">
                            {{this.created_at}}
                        </p>
                    </div>
                </div>
            </div>
        </article>
        {{/each}}
    </div>

    <div class="max-w-5xl mx-auto py-10 px-4">
    
        {{{ paginate blogs }}}

    </div>

    {{#if (eq blogs.data.length 0)}}
    <div class="text-center py-20 border-2 border-dashed border-gray-200 rounded-lg">
        <p class="text-gray-500">Belum ada artikel yang diterbitkan.</p>
    </div>
    {{/if}}

</section>